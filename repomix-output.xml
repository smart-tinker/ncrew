                )
                if not token or len(token) < 20:
                    result.status = "FAIL"
                    result.message = "Invalid Telegram bot token format"

            result.details = {
                "env_file_exists": True,
                "required_vars": len(
                    [v for v in required_vars if f"{v}=" in env_content]
                ),
