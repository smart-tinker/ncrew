                            </div>
                            <div class="form-group">
                                <label>Тип агента</label>
                                <select name="agent_type" onchange="updateCliCommand(this)">
                                    <option value="gemini_acp" {% if role.agent_type == 'gemini_acp' %}selected{% endif %}>Gemini (ACP)</option>
                                    <option value="opencode_acp" {% if role.agent_type == 'opencode_acp' %}selected{% endif %}>OpenCode (ACP)</option>
                                    <option value="qwen_acp" {% if role.agent_type == 'qwen_acp' %}selected{% endif %}>Qwen (ACP)</option>
                                    <option value="codex_cli" {% if role.agent_type == 'codex_cli' %}selected{% endif %}>Codex CLI</option>
                                    <option value="claude_cli" {% if role.agent_type == 'claude_cli' %}selected{% endif %}>Claude CLI</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>CLI команда</label>
                                <div class="input-group">
                                    <input type="text" name="cli_command" value="{{ role.cli_command }}">
                                    <button type="button" class="btn btn-secondary" onclick="toggleBuilder(this)" title="Конструктор опций">
                                        <i class="fas fa-sliders-h"></i>
                                    </button>
                                    <button type="button" class="btn btn-danger" onclick="resetToDefault(this)" title="Сбросить к стандартным">
                                        <i class="fas fa-undo"></i>
                                    </button>
                                </div>
                                <div class="cli-builder-container" style="margin-top: 10px; padding: 15px; border: 1px solid var(--border-color); border-radius: 4px; background-color: var(--bg-color); display: none;">
                                    <!-- Builder content will be rendered here -->
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Токен Telegram бота</label>
                                <input type="text" name="telegram_bot_token" value="{{ role.telegram_bot_token }}">
                            </div>
