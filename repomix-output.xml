{% block scripts %}
    <script>
        const messagesContainer = document.getElementById('messagesContainer');
        const messageInput = document.getElementById('messageInput');
        const sendButton = document.getElementById('sendButton');
        const messageCountLabel = document.getElementById('messageCountLabel');
        const errorContainer = document.getElementById('errorContainer');
        const messageForm = document.getElementById('messageForm');

        let lastMessageIndex = 0;
        let allMessages = [];
        let roleColors = {};
        let isLoading = false;
        let updateInterval = null;

        // Role color palette
        const colorPalette = [
            '#FF6B6B', '#4ECDC4', '#45B7D1', '#FFA07A', '#98D8C8',
            '#F7DC6F', '#BB8FCE', '#85C1E2', '#F8B88B', '#85E1A0'
        ];

        // Initialize
        async function init() {
            try {
                await loadMessages();
                enableInput();
                startPolling();
            } catch (error) {
                showError('Ошибка инициализации: ' + error.message);
            }
        }

        // Load message history
        async function loadMessages() {
            try {
                const response = await fetch('/api/chat/history');
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                
                const data = await response.json();
                allMessages = data.messages || [];
                
                renderMessages();
                updateMessageCount();
                
                if (allMessages.length > 0) {
                    lastMessageIndex = allMessages.length;
                    scrollToBottom();
                }
            } catch (error) {
                console.error('Failed to load messages:', error);
                throw error;
            }
        }

        // Render messages
        function renderMessages() {
            if (allMessages.length === 0) {
                messagesContainer.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-inbox"></i>
                        <p>История сообщений пуста</p>
                    </div>
                `;
                return;
            }

            messagesContainer.innerHTML = '';

            allMessages.forEach((msg, idx) => {
                const messageEl = createMessageElement(msg);
                messagesContainer.appendChild(messageEl);
            });
        }

        // Create message DOM element
        function createMessageElement(msg) {
            const div = document.createElement('div');
            const isUser = msg.role === 'user';
            const roleLabel = msg.role_display || msg.role || 'Неизвестный';
            
            // Assign color to role if not exists
            if (!roleColors[roleLabel]) {
                roleColors[roleLabel] = colorPalette[Object.keys(roleColors).length % colorPalette.length];
            }

            const timeStr = formatTime(msg.timestamp);
            const roleStyle = isUser ? '' : `color: ${roleColors[roleLabel]};`;

            div.className = `message ${isUser ? 'user' : 'agent'}`;
            div.innerHTML = `
                <div class="message-meta">
                    <span class="role-label" style="${roleStyle}">
                        ${isUser ? '👤 Вы' : '🤖 ' + roleLabel}
                    </span>
                </div>
                <div class="message-content">${escapeHtml(msg.text || msg.content || '')}</div>
                <div class="message-meta">${timeStr}</div>
            `;

            return div;
        }

        // Format timestamp
        function formatTime(timestamp) {
            if (!timestamp) return '';
            try {
                const date = new Date(timestamp);
                return date.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
            } catch {
                return '';
            }
        }

        // Escape HTML
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Send message
        async function sendMessage(event) {
            event.preventDefault();
            
            const text = messageInput.value.trim();
            if (!text) return;

            sendButton.disabled = true;
            messageInput.disabled = true;
            const originalIcon = sendButton.innerHTML;
            sendButton.innerHTML = '<span class="loading-spinner"></span>';

            try {
                const response = await fetch('/api/chat/message', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text })
                });

                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.error || `HTTP ${response.status}`);
                }

                messageInput.value = '';
                clearError();
                
                // Reload messages
                await loadMessages();
                scrollToBottom();
            } catch (error) {
                showError('Ошибка при отправке: ' + error.message);
            } finally {
                sendButton.disabled = false;
                messageInput.disabled = false;
                sendButton.innerHTML = originalIcon;
                messageInput.focus();
            }
        }

        // Poll for updates
        async function pollUpdates() {
            try {
                const response = await fetch(`/api/chat/updates?last_index=${lastMessageIndex}`);
                if (!response.ok) return;
                
                const data = await response.json();
                const newMessages = data.messages || [];

                if (newMessages.length > 0) {
                    allMessages = [...allMessages, ...newMessages];
                    renderMessages();
                    updateMessageCount();
                    lastMessageIndex = allMessages.length;
                    scrollToBottom();
                }
            } catch (error) {
                console.error('Failed to poll updates:', error);
            }
        }

        // Start polling for new messages
        function startPolling() {
            updateInterval = setInterval(pollUpdates, 2000); // Poll every 2 seconds
        }

        // Stop polling
        function stopPolling() {
            if (updateInterval) {
                clearInterval(updateInterval);
                updateInterval = null;
            }
        }

        // Scroll to bottom
        function scrollToBottom() {
            setTimeout(() => {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }, 0);
        }

        // Update message count
        function updateMessageCount() {
            messageCountLabel.textContent = `Сообщений: ${allMessages.length}`;
        }

        // Enable input
        function enableInput() {
            messageInput.disabled = false;
            sendButton.disabled = false;
        }

        // Show error
        function showError(message) {
            const div = document.createElement('div');
            div.className = 'error-message';
            div.textContent = message;
            errorContainer.innerHTML = '';
            errorContainer.appendChild(div);
            
            setTimeout(() => {
                div.remove();
            }, 5000);
        }

        // Clear error
        function clearError() {
            errorContainer.innerHTML = '';
        }

        // Dark mode toggle
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
        }

        // Load dark mode preference
        function loadDarkModePreference() {
            if (localStorage.getItem('darkMode') === 'true') {
                document.body.classList.add('dark-mode');
            }
        }

        // Cleanup on page unload
        window.addEventListener('beforeunload', () => {
            stopPolling();
        });

        // Start on load
        loadDarkModePreference();
        init();
    </script>
{% endblock %}
</file>

