def run_web_server():
    import time
    import logging

    retries = 5
    port = 8080

    while retries > 0:
        try:
            app.run(host="0.0.0.0", port=port, use_reloader=False)
            break
        except OSError as e:
            if "Address already in use" in str(e) and retries > 0:
                logging.warning(
                    f"Port {port} is busy, retrying in 1 second... ({retries} retries left)"
                )
                time.sleep(1.0)
                retries -= 1
            else:
                raise


if __name__ == "__main__":
