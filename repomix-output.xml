        function toggleBuilder(button) {
            const container = button.closest('.form-group').querySelector('.cli-builder-container');
            const roleBody = button.closest('.role-body');
            const agentType = roleBody.querySelector('[name="agent_type"]').value;
            
            if (container.style.display === 'none') {
                renderBuilder(agentType, container);
                container.style.display = 'block';
                button.innerHTML = '<i class="fas fa-times"></i> Скрыть опции';
            } else {
                container.style.display = 'none';
                button.innerHTML = '<i class="fas fa-sliders-h"></i> Опции';
            }
        }

        function renderBuilder(agentType, container) {
            const config = CLI_CONFIG[agentType];
            if (!config) {
                container.innerHTML = '<p class="text-muted">Для этого агента нет доступных опций настройки.</p>';
                return;
            }

            const currentCommand = container.closest('.form-group').querySelector('[name="cli_command"]').value;
            
            let html = '<div class="builder-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px;">';
            
            config.options.forEach((opt, index) => {
                if (opt.type === 'flag') {
                    const isChecked = currentCommand.includes(opt.flag) || (opt.required && !currentCommand) || (opt.checked && !currentCommand);
                    const disabled = opt.required ? 'disabled' : '';
                    const title = opt.description || '';
                    
                    html += `
                        <div class="builder-item" title="${title}">
                            <label style="font-weight: normal; cursor: pointer; display: flex; align-items: center;">
                                <input type="checkbox" 
                                    data-flag="${opt.flag}" 
                                    ${isChecked ? 'checked' : ''} 
                                    ${disabled}
                                    onchange="updateCommandString(this.closest('.cli-builder-container'))"
                                    style="width: auto; margin-right: 8px;">
                                ${opt.label}
                                ${opt.required ? '<span style="color: red; margin-left: 4px;">*</span>' : ''}
                            </label>
                        </div>
                    `;
                } else if (opt.type === 'select') {
                    // Simple parsing to find selected value in current command
                    let selectedValue = opt.default;
                    // Regex to find flag value: --flag value or --flag=value
                    // This is a basic heuristic
                    if (currentCommand) {
                        const regex = new RegExp(`${opt.flag}[=\\s]+([^\\s]+)`);
                        const match = currentCommand.match(regex);
                        if (match) {
                            selectedValue = match[1];
                        }
                    }

                    html += `
                        <div class="builder-item" title="${opt.description || ''}">
                            <label style="font-size: 0.85rem; margin-bottom: 2px;">${opt.label}</label>
                            <select 
                                data-flag="${opt.flag}" 
                                onchange="updateCommandString(this.closest('.cli-builder-container'))"
                                style="padding: 4px; font-size: 0.9rem;">
                                <option value="">(Не задано)</option>
                                ${opt.values.map(v => `
                                    <option value="${v.value}" ${v.value === selectedValue ? 'selected' : ''}>${v.label}</option>
                                `).join('')}
                            </select>
                        </div>
                    `;
                }
            });
            
            html += '</div>';
            container.innerHTML = html;
        }

        function updateCommandString(container) {
            const roleBody = container.closest('.role-body');
            const agentType = roleBody.querySelector('[name="agent_type"]').value;
            const config = CLI_CONFIG[agentType];
            const input = roleBody.querySelector('[name="cli_command"]');
            
            if (!config) return;

            let commandParts = [config.base];
            
            // Process flags
            container.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                if (cb.checked) {
                    commandParts.push(cb.dataset.flag);
                }
            });

            // Process selects
            container.querySelectorAll('select').forEach(sel => {
                if (sel.value) {
                    commandParts.push(sel.dataset.flag);
                    commandParts.push(sel.value);
                }
            });

            input.value = commandParts.join(' ');
        }

        function resetToDefault(button) {
            if (!confirm('Сбросить команду к рекомендованным настройкам?')) return;
            
            const roleBody = button.closest('.role-body');
            const selectElement = roleBody.querySelector('[name="agent_type"]');
            
            // This re-triggers the update logic which applies defaults
            updateCliCommand(selectElement);
        }

        function updateCliCommand(selectElement) {
            const agentType = selectElement.value;
            const roleBody = selectElement.closest('.role-body');
            const cliCommandInput = roleBody.querySelector('[name="cli_command"]');
            const container = roleBody.querySelector('.cli-builder-container');
            
            // Reset command to default constructed string
            // We do this by rendering the builder with "empty" current command context
            // ensuring defaults from config are applied
            if (CLI_CONFIG[agentType]) {
                // Temporarily clear input to force defaults in renderBuilder
                const oldVal = cliCommandInput.value;
                cliCommandInput.value = ''; 
                renderBuilder(agentType, container);
                updateCommandString(container);
            } else {
                cliCommandInput.value = '';
                container.innerHTML = '';
            }
            
            // If builder was open, refresh it
            if (container.style.display !== 'none') {
                renderBuilder(agentType, container);
            }
        }

        function sanitizeBotName(roleName) {
            if (!roleName) {
                return 'New_Role_Bot';
            }
            let candidate = roleName.trim().replace(/[^A-Za-z0-9_]+/g, '_');
            candidate = candidate.replace(/_+/g, '_').replace(/^_+|_+$/g, '');
            if (!candidate) {
                candidate = 'New_Role';
            }
            if (!candidate.toLowerCase().endsWith('_bot')) {
                candidate += '_Bot';
            }
            return candidate;
        }

