                {% endfor %}
            </div>
            <div class="actions">
                <button type="button" class="btn btn-primary" onclick="addRole()"><i class="fas fa-plus"></i> Добавить роль</button>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Сохранить и перезагрузить</button>
            </div>
        </form>
    </div>

