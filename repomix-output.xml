<body>
    <!-- Dark mode toggle -->
    <div class="dark-mode-toggle" onclick="toggleDarkMode()">
        <i class="fas fa-moon"></i>
    </div>

    <div class="main-container">
        <!-- Левая колонка - редактор ролей проекта -->
        <div class="roles-panel">
            <div class="panel-header">
                <h1 class="panel-title">Редактор ролей проекта</h1>
                <div>
                    <button onclick="addRole()" class="btn btn-success">
                        <i class="fas fa-plus"></i> Добавить роль
                    </button>
                </div>
            </div>

            <div class="project-info">
                <strong>Текущий проект:</strong> <span class="project-name">{{ current_project or 'Не выбран' }}</span>
            </div>

            <form action="/save" method="post" id="roles-form">
                <div id="roles-container">
                    {% for role in roles %}
                    <div class="role" data-id="{{ loop.index0 }}">
                        <div class="role-header">
                            <h3 class="role-name">{{ role.role_name }}</h3>
                            <button type="button" class="btn btn-danger btn-small" onclick="removeRole(this)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                        <div class="role-body">
                            <input type="hidden" name="role_name" value="{{ role.role_name }}">
                            <input type="hidden" name="telegram_bot_name" value="{{ role.telegram_bot_name }}">
                            <input type="hidden" name="is_moderator" value="{{ 'true' if role.get('is_moderator') else 'false' }}">

                            <div class="form-grid">
                                <div class="form-group">
                                    <label>Отображаемое имя</label>
                                    <input type="text" name="display_name" value="{{ role.display_name }}">
                                </div>

                                <div class="form-group">
                                    <label>Файл промпта</label>
                                    <select name="prompt_file" id="prompt-select-{{ loop.index0 }}">
                                        <option value="">-- Выберите промпт --</option>
                                        <!-- Options will be populated by JavaScript -->
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>Тип агента</label>
                                    <select name="agent_type" onchange="updateCliCommand(this)">
                                        <option value="gemini_acp" {% if role.agent_type == 'gemini_acp' %}selected{% endif %}>Gemini (ACP)</option>
                                        <option value="opencode_acp" {% if role.agent_type == 'opencode_acp' %}selected{% endif %}>OpenCode (ACP)</option>
                                        <option value="qwen_acp" {% if role.agent_type == 'qwen_acp' %}selected{% endif %}>Qwen (ACP)</option>
                                        <option value="codex_cli" {% if role.agent_type == 'codex_cli' %}selected{% endif %}>Codex CLI</option>
                                        <option value="claude_cli" {% if role.agent_type == 'claude_cli' %}selected{% endif %}>Claude CLI</option>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label>CLI команда</label>
                                    <div class="input-group">
                                        <input type="text" name="cli_command" value="{{ role.cli_command }}">
                                        <button type="button" class="btn btn-secondary btn-small" onclick="toggleBuilder(this)" title="Конструктор опций">
                                            <i class="fas fa-sliders-h"></i>
                                        </button>
                                        <button type="button" class="btn btn-danger btn-small" onclick="resetToDefault(this)" title="Сбросить к стандартным">
                                            <i class="fas fa-undo"></i>
                                        </button>
                                    </div>
                                    <div class="cli-builder-container">
                                        <!-- Builder content will be rendered here -->
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label>Токен Telegram бота</label>
                                    <input type="text" name="telegram_bot_token" value="{{ role.telegram_bot_token }}">
                                </div>

                                <div class="form-group">
                                    <label style="font-weight: normal; cursor: pointer; display: flex; align-items: center;">
                                        <input type="checkbox"
                                               style="width: auto; margin-right: 10px;"
                                               onchange="this.closest('.role-body').querySelector('input[name=is_moderator]').value = this.checked"
                                               {% if role.get('is_moderator') %}checked{% endif %}>
                                        <strong>Модератор</strong>
                                    </label>
                                    <small class="text-muted">Имеет право останавливать автономный диалог</small>
                                </div>

                                <div class="form-group full-width">
