        </div>

        <!-- Правая колонка - редактор промптов -->
        <div class="prompts-panel">
            <div class="panel-header">
                <h2 class="panel-title">Редактор промптов</h2>
                <div>
                    <button onclick="openNewPromptModal()" class="btn btn-success">
                        <i class="fas fa-plus"></i> Новый промпт
                    </button>
                </div>
            </div>

            <div class="prompts-list">
                <div class="prompts-header">
                    <h3>Файлы промптов</h3>
                </div>
                <div id="prompts-container">
                    <!-- Prompts will be loaded here -->
                </div>
            </div>

            <div class="prompt-editor hidden" id="prompt-editor">
                <div class="editor-header">
                    <h3 class="editor-title" id="editor-title">Редактирование промпта</h3>
                    <div>
                        <button onclick="savePrompt()" class="btn btn-primary btn-small">
                            <i class="fas fa-save"></i> Сохранить
                        </button>
                        <button onclick="closeEditor()" class="btn btn-secondary btn-small">
                            <i class="fas fa-times"></i> Закрыть
                        </button>
                    </div>
                </div>
                <div class="editor-content">
                    <textarea id="prompt-content" class="editor-textarea" placeholder="Введите содержимое промпта..."></textarea>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for creating new prompt -->
    <div id="new-prompt-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Создать новый промпт</h2>
                <span class="close-button" onclick="closeNewPromptModal()">&times;</span>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="new-prompt-name">Имя файла промпта (без .md)</label>
                    <input type="text" id="new-prompt-name" placeholder="architect_v2">
                    <small class="text-muted">Используйте только буквы, цифры, подчеркивания и дефисы</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeNewPromptModal()">Отмена</button>
                <button type="button" class="btn btn-primary" onclick="createPrompt()">Создать</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        let currentPrompt = null;
        let availablePrompts = [];

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            loadPrompts();
            initializeSortable();
            loadDarkMode();
        });

        // Load available prompts
        async function loadPrompts() {
            try {
                const response = await fetch('/api/prompts/list');
                const data = await response.json();

                if (data.prompts) {
                    availablePrompts = data.prompts;
                    updatePromptsList();
                    updatePromptSelects();
                }
            } catch (error) {
                console.error('Error loading prompts:', error);
            }
        }

        // Update prompts list in the right panel
        function updatePromptsList() {
            const container = document.getElementById('prompts-container');
            container.innerHTML = '';

            availablePrompts.forEach(promptName => {
                const promptItem = document.createElement('div');
                promptItem.className = 'prompt-item';
                promptItem.onclick = () => loadPrompt(promptName);

                promptItem.innerHTML = `
                    <span class="prompt-name">${promptName}.md</span>
                    <div class="prompt-actions">
                        <button onclick="event.stopPropagation(); deletePrompt('${promptName}')" class="btn btn-danger btn-small" title="Удалить">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `;

                container.appendChild(promptItem);
            });
        }

        // Update prompt selects in role forms
        function updatePromptSelects() {
            const selects = document.querySelectorAll('[name="prompt_file"]');
            selects.forEach(select => {
                const currentValue = select.value;
                select.innerHTML = '<option value="">-- Выберите промпт --</option>';

                availablePrompts.forEach(promptName => {
                    const option = document.createElement('option');
                    option.value = promptName;
                    option.textContent = `${promptName}.md`;
                    if (currentValue === promptName) {
                        option.selected = true;
                    }
                    select.appendChild(option);
                });
            });
        }

        // Load prompt content
        async function loadPrompt(promptName) {
            try {
                const response = await fetch(`/prompt?filepath=${promptName}.md`);
                const data = await response.json();

                if (data.content !== undefined) {
                    currentPrompt = promptName;
                    document.getElementById('editor-title').textContent = `Редактирование: ${promptName}.md`;
                    document.getElementById('prompt-content').value = data.content;
                    document.getElementById('prompt-editor').classList.remove('hidden');

                    // Highlight active prompt
                    document.querySelectorAll('.prompt-item').forEach(item => {
                        item.classList.remove('active');
                    });
                    event.target.closest('.prompt-item').classList.add('active');
                }
            } catch (error) {
                console.error('Error loading prompt:', error);
                alert('Ошибка загрузки промпта');
            }
        }

        // Save prompt
        async function savePrompt() {
            if (!currentPrompt) return;

            const content = document.getElementById('prompt-content').value;

            try {
                const response = await fetch('/prompt', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        filepath: `${currentPrompt}.md`,
                        content: content
                    })
                });

                const data = await response.json();

                if (data.message) {
                    alert('Промпт сохранён успешно');
                    loadPrompts(); // Refresh list
                } else {
                    alert('Ошибка сохранения: ' + (data.error || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error saving prompt:', error);
                alert('Ошибка сохранения промпта');
            }
        }

        // Create new prompt
        async function createPrompt() {
            const promptName = document.getElementById('new-prompt-name').value.trim();

            if (!promptName) {
                alert('Введите имя промпта');
                return;
            }

            try {
                const response = await fetch('/api/prompts/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        prompt_name: promptName
                    })
                });

                const data = await response.json();

                if (data.success) {
                    closeNewPromptModal();
                    document.getElementById('new-prompt-name').value = '';
                    loadPrompts();
                    loadPrompt(promptName); // Open the new prompt for editing
                } else {
                    alert('Ошибка создания: ' + (data.error || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error creating prompt:', error);
                alert('Ошибка создания промпта');
            }
        }

        // Delete prompt
        async function deletePrompt(promptName) {
            if (!confirm(`Удалить промпт "${promptName}.md"?`)) return;

            try {
                // For now, we'll just remove from the list. In a real implementation,
                // you'd need a delete endpoint
                alert('Удаление промптов пока не реализовано в API');
            } catch (error) {
                console.error('Error deleting prompt:', error);
            }
        }

        // Modal functions
        function openNewPromptModal() {
            document.getElementById('new-prompt-modal').style.display = 'block';
        }

        function closeNewPromptModal() {
            document.getElementById('new-prompt-modal').style.display = 'none';
        }

        function closeEditor() {
            document.getElementById('prompt-editor').classList.add('hidden');
            currentPrompt = null;
            document.querySelectorAll('.prompt-item').forEach(item => {
                item.classList.remove('active');
            });
        }

        // Role management
        function addRole() {
            // This would need to be implemented - for now just show a message
            alert('Добавление ролей пока не реализовано в новом интерфейсе');
        }

        function removeRole(button) {
            if (confirm('Удалить эту роль?')) {
                button.closest('.role').remove();
            }
        }

        // Sortable roles
        function initializeSortable() {
            const container = document.getElementById('roles-container');
            if (container) {
                Sortable.create(container, {
                    animation: 150,
                    ghostClass: 'blue-background-class',
                    handle: '.role-header'
                });
            }
        }

        // CLI Builder functions
        function toggleBuilder(button) {
            const container = button.closest('.form-group').querySelector('.cli-builder-container');
            container.style.display = container.style.display === 'none' ? 'block' : 'none';
        }

        function resetToDefault(button) {
            // Reset CLI command to default based on agent type
            const formGroup = button.closest('.form-group');
            const agentType = formGroup.closest('.role-body').querySelector('[name="agent_type"]').value;
            const cliInput = formGroup.querySelector('[name="cli_command"]');

            const defaults = {
                'gemini_acp': 'gemini',
                'opencode_acp': 'opencode acp',
                'qwen_acp': 'qwen',
                'codex_cli': 'codex',
                'claude_cli': 'claude'
            };

            cliInput.value = defaults[agentType] || '';
        }

        function updateCliCommand(select) {
            const agentType = select.value;
            const cliInput = select.closest('.role-body').querySelector('[name="cli_command"]');

            if (!cliInput.value) {
                const defaults = {
                    'gemini_acp': 'gemini',
                    'opencode_acp': 'opencode acp',
                    'qwen_acp': 'qwen',
                    'codex_cli': 'codex',
                    'claude_cli': 'claude'
                };
                cliInput.value = defaults[agentType] || '';
            }
        }

        // Dark mode
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            const icon = document.querySelector('.dark-mode-toggle i');

            if (document.body.classList.contains('dark-mode')) {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
                localStorage.setItem('darkMode', 'true');
            } else {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
                localStorage.setItem('darkMode', 'false');
            }
        }

        function loadDarkMode() {
            const darkMode = localStorage.getItem('darkMode') === 'true';
            if (darkMode) {
                document.body.classList.add('dark-mode');
                const icon = document.querySelector('.dark-mode-toggle i');
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
            }
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            const modals = document.querySelectorAll('.modal');
            modals.forEach(modal => {
                if (event.target === modal) {
                    modal.style.display = 'none';
                }
            });
        };
    </script>
