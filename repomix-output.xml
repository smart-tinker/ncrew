    ```python
    # ncrew.py
    from typing import AsyncGenerator, Tuple
    
    class NeuroCrewLab:
        # ...
        async def handle_message(self, chat_id: int, user_text: str) -> AsyncGenerator[Tuple[RoleConfig, str], None]:
            """
            Обрабатывает сообщение пользователя, запуская автономный цикл общения ролей.
            Yield-ит кортеж (RoleConfig, raw_response) для каждого ответа роли.
            """
            # ... (логика сохранения сообщения пользователя) ...
    
            # --- НОВАЯ ЛОГИКА ЦИКЛА ---
            
            # Получаем полную последовательность ролей для этого цикла
            roles_to_process = self.role_sequence # В будущем можно будет передавать кастомную
    
            for role_config in roles_to_process:
                self.logger.info(f"Активация роли: {role_config.role_name}")
    
                # Проверяем доступность (упрощенная проверка)
                connector = self._get_or_create_role_connector(role_config)
                if not connector.is_alive():
                     try:
                         await connector.launch(role_config.command, role_config.system_prompt)
                     except Exception as e:
                         self.logger.error(f"Не удалось запустить роль {role_config.role_name}: {e}")
                         # Отправляем сообщение об ошибке и ПРЕРЫВАЕМ цикл
                         yield (role_config, f"❌ Роль {role_config.display_name} не смогла запуститься.")
                         return

                # Обрабатываем с текущей ролью
                raw_response = await self._process_with_role(chat_id, role_config)
    
                # Возвращаем результат для отправки в Telegram
                yield (role_config, raw_response)

                # Проверяем, нужно ли остановить цикл (например, если агент дал пустой ответ)
                if not raw_response or raw_response.strip() == '.....':
                    self.logger.info(f"Роль {role_config.role_name} завершила диалог. Цикл остановлен.")
                    break
    ```
    *   [ ] **Метод `_process_with_role`** теперь принимает **всю** историю диалога (`conversation_history`), а не только "дельту", так как каждый агент в цикле должен видеть, что сказали предыдущие. Он формирует `full_prompt` и вызывает `connector.execute(full_prompt)`.

